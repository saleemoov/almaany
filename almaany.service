 [Unit]
Description=Almaany Crypto Trading Bot
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=root
WorkingDirectory=/root/almaany
ExecStart=/usr/bin/python3 /root/almaany/main.py
Restart=always
RestartSec=10
StandardOutput=append:/root/almaany/bot.log
StandardError=append:/root/almaany/bot.log

[Install]
WantedBy=multi-user.target
WantedBy=multi-user.target
